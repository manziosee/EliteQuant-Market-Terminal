{
  "buildCommand": "npm run build && npm run build:api",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/handler" },
    { "source": "/api-docs", "destination": "/api/handler" },
    { "source": "/api-docs/:path*", "destination": "/api/handler" }
  ]
}
